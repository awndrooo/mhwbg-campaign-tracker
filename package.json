{
  "name": "mhwbg-campaign-tracker",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host=127.0.0.1",
    "build": "ng build --base-href=https://mhwbg.awndroo.art/ --configuration=production",
    "build-dev": "ng build --base-href=./ --configuration=development & npm run postbuild",
    "watch": "ng build --watch --base-href=./ --configuration=development",
    "test": "ng test --debug",
    "test:prod": "ng test --watch=false --coverage",
    "setnode": "nvm use 24.14.0",
    "json-server": "json-server --watch src/assets/db.json",
    "postbuild": "node post-build.js"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.0",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-browser-dynamic": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@ngrx/effects": "^21.0.1",
    "@ngrx/entity": "^21.0.1",
    "@ngrx/operators": "^21.0.1",
    "@ngrx/store": "^21.0.1",
    "@ngrx/store-devtools": "^21.0.1",
    "luxon": "^3.7.2",
    "normalize.css": "^8.0.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/core": "^21.2.0",
    "@angular/build": "^21.2.0",
    "@angular/cdk": "^21.2.0",
    "@angular/cli": "~21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@ngrx/schematics": "^21.0.1",
    "@types/jasmine": "~4.3.0",
    "@types/luxon": "^3.7.1",
    "@typescript-eslint/eslint-plugin": "^5.57.0",
    "@typescript-eslint/parser": "^5.57.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^8.37.0",
    "eslint-config-prettier": "^8.8.0",
    "fake-indexeddb": "^6.2.5",
    "jasmine-core": "~4.5.0",
    "jsdom": "^28.1.0",
    "json-server": "^0.17.3",
    "prettier": "^2.8.7",
    "typescript": "~5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  }
}
